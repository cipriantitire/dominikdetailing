# Supabase - use the new Dominik Detailing Supabase project only.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Use this only if your Supabase dashboard/integration gives an anon key instead
# of a publishable key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Owner/admin auth
# Preferred: comma-separated list of admin emails allowed into owner routes
ADMIN_EMAILS=
# Legacy single-admin fallback
ADMIN_EMAIL=

# Email (Resend)
# API key for Resend
RESEND_API_KEY=
# Owner/admin notification recipient (where owner alerts go)
OWNER_NOTIFICATION_EMAIL=detailingdominik@gmail.com
# Outbound senders - use the verified domain ddetailing.co.uk
# Sender for booking/customer-facing emails
RESEND_BOOKINGS_FROM_EMAIL=bookings@ddetailing.co.uk
# Sender for internal/owner alerts
RESEND_ALERTS_FROM_EMAIL=alerts@ddetailing.co.uk
# Reply-to address for customer-facing emails (human identity)
RESEND_REPLY_FROM_EMAIL=dominik@ddetailing.co.uk
# Optional: legacy single-sender fallback (not recommended)
RESEND_FROM_EMAIL=

# Inbound handling
# Where inbound mail (forwards) should be sent to (e.g., your Gmail)
RESEND_INBOUND_FORWARD_TO=detailingdominik@gmail.com
# Webhook secret for validating inbound events
RESEND_WEBHOOK_SECRET=

# Google Calendar
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_CALENDAR_ID=

# Address lookup (uses postcodes.io, no API key required)
ADDRESS_LOOKUP_RATE_LIMIT_MAX=
ADDRESS_LOOKUP_RATE_LIMIT_WINDOW_SEC=
ADDRESS_LOOKUP_TIMEOUT_MS=

# Public site
NEXT_PUBLIC_SITE_URL=

# Resend template IDs (optional). Paste the template IDs from the Resend dashboard
# to enable HTML template sends. If these are not set the app falls back to
# existing inline/text emails where implemented.
RESEND_TEMPLATE_OWNER_NEW_BOOKING=
RESEND_TEMPLATE_BOOKING_REQUEST_RECEIVED=
RESEND_TEMPLATE_BOOKING_UNDER_REVIEW=
RESEND_TEMPLATE_BOOKING_CONFIRMED=
RESEND_TEMPLATE_BOOKING_DECLINED=
